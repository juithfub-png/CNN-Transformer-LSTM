# ========== 主处理函数 ==========
def process_dataset(records, annotation_ext, is_test=False):
    """处理整个数据集"""
    x_all = []
    y_all = []
    groups_all = []

    print(f"处理{'测试' if is_test else '训练'}集，共 {len(records)} 个记录...")

    with ProcessPoolExecutor(max_workers=num_worker) as executor:
        future_to_record = {}

        for record in records:
            try:
                # 读取注释文件 - 修正：测试集使用.xws扩展名
                annotation_path = os.path.join(base_dir, record)
                annotation = wfdb.rdann(annotation_path, extension=annotation_ext)

                # 提交处理任务
                future = executor.submit(extract_5min_segment_features,
                                         record, annotation.symbol, is_test)
                future_to_record[future] = record

            except Exception as e:
                print(f"无法读取记录 {record} 的注释 {annotation_ext}: {e}")
                continue

        # 处理结果
        for future in tqdm(as_completed(future_to_record),
                           total=len(future_to_record),
                           desc=f"{'测试' if is_test else '训练'}集处理"):
            record = future_to_record[future]
            try:
                x_part, y_part, groups_part, durations = future.result()
                x_all.extend(x_part)
                y_all.extend(y_part)
                groups_all.extend(groups_part)

                if len(x_part) > 0:
                    print(f"  {record}: 提取了 {len(x_part)} 个5分钟段")

            except Exception as e:
                print(f"处理记录 {record} 时出错: {e}")

    return x_all, np.array(y_all), np.array(groups_all)


# ========== 数据标准化（根据论文方法） ==========
def standardize_features(x_features):
    """
    标准化特征（根据论文，可能使用标准化或归一化）
    这里使用论文中可能使用的方法
    """
    if len(x_features) == 0:
        return np.array([])

    # 转换为numpy数组
    # x_features是列表，每个元素是[(rri_tm, rri_signal), (amp_tm, amp_signal)]
    # 我们需要提取插值后的特征

    # 首先插值所有特征到统一长度
    interp_time = np.linspace(0, 300, segment_length)  # 5分钟=300秒

    processed_features = []
    for (rri_tm, rri_signal), (amp_tm, amp_signal) in x_features:
        try:
            # 插值RRI
            if len(rri_tm) >= 4:
                rri_spline = splrep(rri_tm, rri_signal, k=3)
                rri_interp = splev(interp_time, rri_spline, ext=1)
            else:
                rri_interp = np.interp(interp_time, rri_tm, rri_signal)

            # 插值振幅
            if len(amp_tm) >= 4:
                amp_spline = splrep(amp_tm, amp_signal, k=3)
                amp_interp = splev(interp_time, amp_spline, ext=1)
            else:
                amp_interp = np.interp(interp_time, amp_tm, amp_signal)

            # 组合特征
            combined = np.stack([rri_interp, amp_interp], axis=1)  # (900, 2)
            processed_features.append(combined)

        except Exception as e:
            print(f"特征插值错误: {e}")
            continue

    if len(processed_features) == 0:
        return np.array([])

    features_array = np.array(processed_features)  # (n_samples, 900, 2)

    # 标准化：每个特征通道独立标准化
    standardized = np.zeros_like(features_array)

    for channel in range(2):  # RRI和振幅两个通道
        channel_data = features_array[:, :, channel]

        # 计算均值和标准差
        mean_val = np.mean(channel_data)
        std_val = np.std(channel_data)

        if std_val < 1e-8:
            std_val = 1.0

        # 标准化
        standardized[:, :, channel] = (channel_data - mean_val) / std_val

    return standardized


