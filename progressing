# ========== 根据论文方法的处理函数 ==========
def preprocess_ecg_segment(signal, fs=100):
    """根据论文3.2节预处理ECG信号段"""
    try:
        # 1. 滤波：论文中提到使用FIR带通滤波器
        signal_filtered, _, _ = st.filter_signal(signal,
                                                 ftype='FIR',
                                                 band='bandpass',
                                                 order=int(0.3 * fs),
                                                 frequency=[3, 45],
                                                 sampling_rate=fs)

        # 2. R峰检测：使用Hamilton算法（论文3.2节提到）
        rpeaks, = hamilton_segmenter(signal_filtered, sampling_rate=fs)
        rpeaks, = correct_rpeaks(signal_filtered, rpeaks=rpeaks,
                                 sampling_rate=fs, tol=0.1)

        if len(rpeaks) < 4:  # 需要至少4个R峰才能进行插值
            return None, None, None, None

        # 3. 计算RR间期和R峰振幅
        rri_tm = rpeaks[1:] / float(fs)  # RRI时间点（从第二个R峰开始）
        rri_signal = np.diff(rpeaks) / float(fs)  # RRI值

        # 4. 中值滤波去除异常值（论文3.2节提到）
        if len(rri_signal) >= 3:
            rri_signal = medfilt(rri_signal, kernel_size=3)

        # 5. 提取R峰振幅
        amp_tm = rpeaks / float(fs)
        amp_signal = signal_filtered[rpeaks]

        return rri_tm, rri_signal, amp_tm, amp_signal

    except Exception as e:
        print(f"预处理错误: {e}")
        return None, None, None, None


def extract_5min_segment_features(name, labels, is_test=False):
    """
    根据论文方法提取5分钟段的特征
    论文中使用5分钟段（前2分钟+目标1分钟+后2分钟）
    """
    x_raw = []  # 存储原始特征
    y = []  # 存储标签
    groups = []  # 存储样本来源
    segment_durations = []  # 存储段持续时间

    # 读取ECG记录
    record_path = os.path.join(base_dir, name)
    try:
        signals = wfdb.rdrecord(record_path, channels=[0]).p_signal[:, 0]
    except Exception as e:
        print(f"错误: 无法读取文件 {name}: {e}")
        return [], [], [], [], []

    total_minutes = len(signals) // (fs * 60)
    print(f"记录 {name}: 总长度 {total_minutes} 分钟")

    # 遍历每一分钟（目标分钟）
    for target_minute in range(before, total_minutes - after):
        try:
            # 提取5分钟窗口：前2分钟 + 目标1分钟 + 后2分钟
            start_sample = (target_minute - before) * sample
            end_sample = (target_minute + 1 + after) * sample

            if end_sample > len(signals):
                break

            segment_signal = signals[start_sample:end_sample]

            # 预处理5分钟段
            rri_tm, rri_signal, amp_tm, amp_signal = preprocess_ecg_segment(segment_signal, fs)

            if rri_tm is None or len(rri_signal) < 10:
                continue  # 跳过质量差的段

            # 检查RRI的合理性（根据论文心率范围）
            hr = 60 / rri_signal
            if np.any(hr < 20) or np.any(hr > 300):
                continue  # 跳过心率异常的段

            # 归一化RRI和振幅（论文中提到归一化）
            def normalize_to_unit(sig):
                sig_min, sig_max = np.min(sig), np.max(sig)
                if sig_max - sig_min > 1e-8:
                    return (sig - sig_min) / (sig_max - sig_min)
                else:
                    return np.zeros_like(sig)

            rri_normalized = normalize_to_unit(rri_signal)
            amp_normalized = normalize_to_unit(amp_signal)

            # 插值到900个点（论文3.2节明确提到）
            try:
                # 创建统一的时间轴：0到5分钟，900个点
                interp_time = np.linspace(0, (before + 1 + after) * 60, segment_length)

                # 使用样条插值（论文中可能使用）
                if len(rri_tm) >= 4:
                    rri_spline = splrep(rri_tm, rri_normalized, k=3)
                    rri_interp = splev(interp_time, rri_spline, ext=1)
                else:
                    rri_interp = np.interp(interp_time, rri_tm, rri_normalized)

                if len(amp_tm) >= 4:
                    amp_spline = splrep(amp_tm, amp_normalized, k=3)
                    amp_interp = splev(interp_time, amp_spline, ext=1)
                else:
                    amp_interp = np.interp(interp_time, amp_tm, amp_normalized)

                # 检查插值结果
                if np.any(np.isnan(rri_interp)) or np.any(np.isnan(amp_interp)):
                    continue

                # 存储处理后的特征（900个点的RRI和振幅）
                processed_features = np.stack([rri_interp, amp_interp], axis=1)  # 形状: (900, 2)

                # 存储原始数据格式（用于模型）
                x_raw.append([(rri_tm, rri_normalized), (amp_tm, amp_normalized)])

                # 标签处理（根据论文，使用AASM标准）
                # 注意：论文中提到的标签是每分钟的注释
                label_char = labels[target_minute] if target_minute < len(labels) else 'N'

                if label_char in ['A', 'a']:
                    y.append(1.0)  # 呼吸暂停
                elif label_char in ['N', 'n', 'B', 'b']:
                    y.append(0.0)  # 正常或边界
                else:
                    # 跳过未知标签
                    continue

                groups.append(name)
                segment_durations.append((before + 1 + after) * 60)  # 5分钟

            except Exception as e:
                if is_test:
                    print(f"  测试集插值错误 {name} 第{target_minute}分钟: {e}")
                continue

        except Exception as e:
            if is_test and target_minute % 30 == 0:  # 每30分钟打印一次
                print(f"  测试集处理错误 {name} 第{target_minute}分钟: {e}")
            continue

    return x_raw, y, groups, segment_durations


